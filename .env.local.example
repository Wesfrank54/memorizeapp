# PowerSync + Supabase configuration for Phase 5 production backend
# Copy to .env.local and fill in your values

# Supabase project (get from https://supabase.com dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# PowerSync instance URL (from your PowerSync dashboard or self-hosted)
VITE_POWERSYNC_URL=https://your-powersync-instance.powersync.journeyapps.com

# Optional: set to 'powersync' to default to real backend (default is 'local' toy)
# VITE_SYNC_BACKEND=powersync
